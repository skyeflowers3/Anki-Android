<?xml version="1.0" encoding="utf-8"?>
<!--
  Root must be a CoordinatorLayout: NavigationDrawerActivity.setContentView wraps this in the
  shared ClosableDrawerLayout (drawer + hamburger) automatically.
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <include layout="@layout/include_toolbar" />

        <!-- The score content (loading / results) is injected here, below the persistent toolbar. -->
        <FrameLayout
            android:id="@+id/speedrun_score_content"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
